# Steam Auto Shutdown — Modern Edition (v6.1.0)
# Extensive Catch-All .gitignore

# --- Logs & Runtime ---
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
pids
*.pid
*.seed
*.pid.lock

# --- Frontend (Node/React) ---
frontend/node_modules/
frontend/dist/
frontend/src/wailsjs/
.npm
.eslintcache
.stylelintcache
node_modules/
jspm_packages/
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/
frontend/src/wailsjs/

# --- Backend (Go) ---
bin/
build/bin/
build/windows/
vendor/
*.exe
*.test
*.prof
*.stackdump

# --- Environment & Tooling ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.history/
.gemini/
/tmp/
.cache
.parcel-cache
.turbo

# --- IDEs (VSCode) ---
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets

# --- IDEs (JetBrains) ---
.idea/
*.iws
*.iml
*.ipr
out/

# --- Operating Systems (Windows) ---
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
[Dd]esktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# --- Operating Systems (macOS) ---
.DS_Store
.AppleDouble
.LSOverride
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# --- Operating Systems (Linux) ---
.directory
.Trash-*
.nfs*
.fuse_hidden*

# --- Coverage & Tests ---
coverage/
*.lcov
.nyc_output
.vscode-test

# --- Archives ---
*.tgz
*.zip
*.tar
*.gz